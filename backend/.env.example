# App
APP_NAME=Nch WA Gateway
ENV=development
DEBUG=true

# Security — WAJIB ganti di production! Generate: openssl rand -hex 32
SECRET_KEY=change-me-please-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma separated, JANGAN pakai * di production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database (PostgreSQL). CATATAN: di Docker, nilai ini DIABAIKAN — DATABASE_URL
# diambil dari .env root (biar gampang switch lokal/Supabase). Baris di bawah
# hanya untuk dev TANPA Docker (uvicorn langsung).
DATABASE_URL=postgresql+psycopg://wa_user:wa_password@localhost:5432/wa_gateway

# Rate limit
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_DEFAULT=100/minute

# Cookie (production: COOKIE_SECURE=true)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Scheduler
SCHEDULER_TIMEZONE=Asia/Jakarta
# Optional: alert ke Google Chat kalau job gagal (kosongkan untuk disable)
GOOGLE_CHAT_WEBHOOK=

# WhatsApp gateway (service Node/Baileys)
# Dev tanpa Docker: WA_GATEWAY_URL=http://localhost:3001
WA_GATEWAY_URL=http://wa-gateway:3001
# 2 nilai ini HARUS sama dengan yang di wa-gateway/.env
WA_INTERNAL_TOKEN=change-me-internal-token
WEBHOOK_SECRET=change-me-webhook-secret
