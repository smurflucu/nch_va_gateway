# =====================================================================
#  Konfigurasi utama (dibaca docker compose). Salin ke `.env` lalu edit.
#      cp .env.example .env
#  Cukup ubah 2 hal untuk ganti database: COMPOSE_PROFILES + DATABASE_URL.
# =====================================================================

# ─────────────────────────────────────────────────────────────────────
# MODE A — Postgres LOKAL via Docker  (default, paling gampang)
#   • COMPOSE_PROFILES=localdb  → service "db" (Postgres) ikut jalan.
#   • DATABASE_URL pakai host "db" (nama service) + kredensial POSTGRES_* di bawah.
# ─────────────────────────────────────────────────────────────────────
COMPOSE_PROFILES=localdb
DATABASE_URL=postgresql+psycopg://wa_user:wa_password@db:5432/wa_gateway

# Kredensial Postgres lokal (dipakai service "db"; samakan dgn DATABASE_URL di atas)
POSTGRES_USER=wa_user
POSTGRES_PASSWORD=wa_password
POSTGRES_DB=wa_gateway
# Port di HOST untuk akses DBeaver/psql (default 5433 agar tak bentrok Postgres lain)
POSTGRES_HOST_PORT=5433

# ─────────────────────────────────────────────────────────────────────
# MODE B — Supabase / Postgres EKSTERNAL
#   1) Matikan Postgres lokal:   COMPOSE_PROFILES=
#   2) Isi DATABASE_URL dgn connection string Supabase:
#      Supabase → Project Settings → Database → Connection string → URI.
#      Disarankan "Session pooler" (port 5432). Ganti driver ke +psycopg,
#      dan tambahkan ?sslmode=require di akhir.
#
#   Contoh:
#   COMPOSE_PROFILES=
#   DATABASE_URL=postgresql+psycopg://postgres.abcdxyz:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
#
# ─────────────────────────────────────────────────────────────────────
# MODE C — Postgres di HOST (bukan Docker)
#   COMPOSE_PROFILES=
#   DATABASE_URL=postgresql+psycopg://user:pass@host.docker.internal:5432/dbname
# ─────────────────────────────────────────────────────────────────────
